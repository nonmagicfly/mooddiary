{
  "realm": "mooddiary",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "clients": [
    {
      "clientId": "mooddiary-web",
      "name": "MoodDiary Web",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://localhost:5173/diary/login",
        "http://localhost:5173/silent-check-sso.html",
        "http://host.docker.internal:5173/*",
        "http://host.docker.internal:5173/diary/login",
        "http://host.docker.internal:5173/silent-check-sso.html",
        "http://127.0.0.1:5173/*",
        "http://127.0.0.1:5173/diary/login",
        "http://127.0.0.1:5173/silent-check-sso.html"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://host.docker.internal:5173",
        "http://127.0.0.1:5173"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    }
  ],
  "users": [
    {
      "username": "test",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "test",
          "temporary": false
        }
      ]
    }
  ]
}
