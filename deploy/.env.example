# MoodDiary production — copy to .env and set secrets:
# cp .env.example .env && nano .env

DOMAIN=app.yourdomain.com
# Optional: separate Keycloak hostname (defaults to DOMAIN)
# AUTH_DOMAIN=auth.yourdomain.com
PROTOCOL=https
DB_PASSWORD=replace_with_secure_password
KEYCLOAK_ADMIN_PASSWORD=replace_with_keycloak_admin_password
KEYCLOAK_DB_PASSWORD=replace_with_keycloak_db_password
TELEGRAM_BOT_TOKEN=

# Optional: custom SSL paths (defaults: deploy/ssl/fullchain.pem, privkey.pem)
# SSL_DIR=./ssl
# SSL_CERT_PATH=/etc/nginx/ssl/fullchain.pem
# SSL_CERT_KEY_PATH=/etc/nginx/ssl/privkey.pem
