# Скопируйте в .env: cp env.mvp.example .env && nano .env
# Логин/пароль по умолчанию: mvp / mvp — смените MVP_AUTH_* в проде.

DOMAIN=diary.example.com
DB_PASSWORD=замените_надёжным_пароль_бд

MVP_AUTH_USERNAME=mvp
MVP_AUTH_PASSWORD=mvp
MVP_AUTH_SUBJECT=mvp

# При занятом порту 80:
# MVP_HTTP_PORT=8080

TELEGRAM_BOT_TOKEN=
