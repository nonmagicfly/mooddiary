# Keycloak — по умолчанию используется Keycloak из docker-compose (host.docker.internal:8180, realm mooddiary).
# Переопределите для другого сервера:
# VITE_KEYCLOAK_ISSUER_URI=http://host.docker.internal:8180/realms/mooddiary
# VITE_KEYCLOAK_CLIENT_ID=mooddiary-web

# API (если не через Vite proxy):
# VITE_API_BASE_URL=
